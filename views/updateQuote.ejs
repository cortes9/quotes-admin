<!DOCTYPE html>
<html>
<head>
    <title>update quote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-4">

    <nav class="mb-3">
        <a href="/authors" class="btn btn-dark btn-sm">authors</a>
        <a href="/quotes" class="btn btn-dark btn-sm">quotes</a>
        <a href="/addAuthor" class="btn btn-success btn-sm">add author</a>
        <a href="/addQuote" class="btn btn-success btn-sm">add quote</a>
        <a href="/logout" class="btn btn-danger btn-sm">logout</a>
    </nav>

    <h2>update quote</h2>

    <form method="POST" action="/updateQuote">
        <input type="hidden" name="quoteId" value="<%= quoteRow.quoteId %>">

        <div class="mb-2">
            <label>quote</label>
            <textarea name="quote" class="form-control" required><%= quoteRow.quote %></textarea>
        </div>

        <div class="mb-2">
            <label>author</label>
            <select name="authorId" class="form-control" required>
                <% authors.forEach(author => { %>
                    <option value="<%= author.authorId %>" <%= author.authorId == quoteRow.authorId ? "selected" : "" %>>
                        <%= author.firstName %> <%= author.lastName %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="mb-2">
            <label>category</label>
            <input list="categoryList" name="category" class="form-control" value="<%= quoteRow.category || '' %>">
            <datalist id="categoryList">
                <% categories.forEach(c => { %>
                    <option value="<%= c.category %>">
                <% }) %>
            </datalist>
        </div>

        <button class="btn btn-primary">update quote</button>
    </form>

</div>
</body>
</html>