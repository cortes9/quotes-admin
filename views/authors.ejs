<!DOCTYPE html>
<html>
<head>
    <title>authors</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-4">

    <nav class="mb-3">
        <a href="/authors" class="btn btn-dark btn-sm">authors</a>
        <a href="/quotes" class="btn btn-dark btn-sm">quotes</a>
        <a href="/addAuthor" class="btn btn-success btn-sm">add author</a>
        <a href="/addQuote" class="btn btn-success btn-sm">add quote</a>
        <a href="/logout" class="btn btn-danger btn-sm">logout</a>
    </nav>

    <h2>authors</h2>

    <table class="table table-bordered table-striped">
        <tr>
            <th>id</th>
            <th>name</th>
            <th>dob</th>
            <th>dod</th>
            <th>profession</th>
            <th>country</th>
            <th>actions</th>
        </tr>

        <% authors.forEach(author => { %>
            <tr>
                <td><%= author.authorId %></td>
                <td><%= author.firstName %> <%= author.lastName %></td>
                <td><%= author.dob || "" %></td>
                <td><%= author.dod || "" %></td>
                <td><%= author.profession || "" %></td>
                <td><%= author.country || "" %></td>
                <td>
                    <a href="/updateAuthor?authorId=<%= author.authorId %>" class="btn btn-warning btn-sm">edit</a>
                    <a href="/deleteAuthor?authorId=<%= author.authorId %>" class="btn btn-danger btn-sm">delete</a>
                </td>
            </tr>
        <% }) %>
    </table>

</div>
</body>
</html>