<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quotes Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('partials/nav') %>
  <div class="container">
    <div class="p-4 bg-white rounded shadow-sm">
      <h1>Admin Section</h1>
      <p class="lead">Welcome, <%= username %>.</p>
      <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" href="/addAuthor">Add Author</a>
        <a class="btn btn-success" href="/addQuote">Add Quote</a>
        <a class="btn btn-outline-dark" href="/authors">All Authors</a>
        <a class="btn btn-outline-dark" href="/quotes">All Quotes</a>
      </div>
    </div>
  </div>
</body>
</html>
