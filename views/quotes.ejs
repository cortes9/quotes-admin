<!DOCTYPE html>
<html>
<head>
    <title>quotes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-4">

    <nav class="mb-3">
        <a href="/authors" class="btn btn-dark btn-sm">authors</a>
        <a href="/quotes" class="btn btn-dark btn-sm">quotes</a>
        <a href="/addAuthor" class="btn btn-success btn-sm">add author</a>
        <a href="/addQuote" class="btn btn-success btn-sm">add quote</a>
        <a href="/logout" class="btn btn-danger btn-sm">logout</a>
    </nav>

    <h2>quotes</h2>

    <table class="table table-bordered table-striped">
        <tr>
            <th>id</th>
            <th>quote</th>
            <th>author</th>
            <th>category</th>
            <th>actions</th>
        </tr>

        <% quotes.forEach(q => { %>
            <tr>
                <td><%= q.quoteId %></td>
                <td><%= q.quote %></td>
                <td><%= q.firstName %> <%= q.lastName %></td>
                <td><%= q.category || "" %></td>
                <td>
                    <a href="/updateQuote?quoteId=<%= q.quoteId %>" class="btn btn-warning btn-sm">edit</a>
                    <a href="/deleteQuote?quoteId=<%= q.quoteId %>" class="btn btn-danger btn-sm">delete</a>
                </td>
            </tr>
        <% }) %>
    </table>

</div>
</body>
</html>